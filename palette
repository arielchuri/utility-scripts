#!/usr/bin/env python3
"""Quick and dirty palette tool - save/load/display color palettes"""

import sys
import os
import webbrowser
import tempfile

def hex_to_rgb(hex_color):
    """Convert hex color to RGB tuple"""
    hex_color = hex_color.lstrip('#')
    return tuple(int(hex_color[i:i+2], 16) for i in (0, 2, 4))

def show_terminal(colors, bg_light='#FFFFFF', bg_dark='#000000'):
    """Display colors in terminal with ANSI codes"""
    # Convert background colors
    bg_light_rgb = hex_to_rgb(bg_light)
    bg_dark_rgb = hex_to_rgb(bg_dark)

    # Calculate width needed (8 chars per color + 3 spacing between + margins)
    num_colors = len(colors)
    content_width = (num_colors * 8) + ((num_colors - 1) * 3)  # Just the content
    panel_width = content_width + 8  # Add 4 char margins on each side

    print("")  # Empty line before panel

    # Build rows for horizontal layout with square blocks
    bg_r, bg_g, bg_b = bg_dark_rgb

    # Top margin (increased) with title
    print(f"\033[48;2;{bg_r};{bg_g};{bg_b}m{' ' * panel_width}\033[0m")
    print(f"\033[48;2;{bg_r};{bg_g};{bg_b}m{' ' * panel_width}\033[0m")
    print(f"\033[48;2;{bg_r};{bg_g};{bg_b}m{' ' * panel_width}\033[0m")
    # Title on background with white text
    title_text = f"On Dark Background ({bg_dark})"
    title_padding = (panel_width - len(title_text)) // 2
    print(f"\033[48;2;{bg_r};{bg_g};{bg_b}m\033[38;2;255;255;255m{' ' * title_padding}{title_text}{' ' * (panel_width - title_padding - len(title_text))}\033[0m")
    print(f"\033[48;2;{bg_r};{bg_g};{bg_b}m{' ' * panel_width}\033[0m")
    print(f"\033[48;2;{bg_r};{bg_g};{bg_b}m{' ' * panel_width}\033[0m")

    # Color blocks (4 rows for square appearance)
    row1 = f"\033[48;2;{bg_r};{bg_g};{bg_b}m    "  # Left margin
    row2 = f"\033[48;2;{bg_r};{bg_g};{bg_b}m    "
    row3 = f"\033[48;2;{bg_r};{bg_g};{bg_b}m    "
    row4 = f"\033[48;2;{bg_r};{bg_g};{bg_b}m    "
    row5 = f"\033[48;2;{bg_r};{bg_g};{bg_b}m    "  # Hex labels

    for i, color in enumerate(colors):
        try:
            r, g, b = hex_to_rgb(color)
            # Square blocks: 8 chars wide, 4 rows tall
            spacing = "   " if i < len(colors) - 1 else ""
            row1 += f"\033[48;2;{r};{g};{b}m        \033[0m\033[48;2;{bg_r};{bg_g};{bg_b}m{spacing}"
            row2 += f"\033[48;2;{r};{g};{b}m        \033[0m\033[48;2;{bg_r};{bg_g};{bg_b}m{spacing}"
            row3 += f"\033[48;2;{r};{g};{b}m        \033[0m\033[48;2;{bg_r};{bg_g};{bg_b}m{spacing}"
            row4 += f"\033[48;2;{r};{g};{b}m        \033[0m\033[48;2;{bg_r};{bg_g};{bg_b}m{spacing}"
            row5 += f"\033[48;2;{bg_r};{bg_g};{bg_b}m\033[38;2;255;255;255m {color:^7}\033[0m\033[48;2;{bg_r};{bg_g};{bg_b}m{spacing}"
        except:
            pass

    # Add right margin and print
    print(row1 + f"\033[48;2;{bg_r};{bg_g};{bg_b}m    \033[0m")
    print(row2 + f"\033[48;2;{bg_r};{bg_g};{bg_b}m    \033[0m")
    print(row3 + f"\033[48;2;{bg_r};{bg_g};{bg_b}m    \033[0m")
    print(row4 + f"\033[48;2;{bg_r};{bg_g};{bg_b}m    \033[0m")
    print(f"\033[48;2;{bg_r};{bg_g};{bg_b}m{' ' * panel_width}\033[0m")  # Spacer
    print(row5 + f"\033[48;2;{bg_r};{bg_g};{bg_b}m    \033[0m")

    # Bottom margin
    print(f"\033[48;2;{bg_r};{bg_g};{bg_b}m{' ' * panel_width}\033[0m")
    print(f"\033[48;2;{bg_r};{bg_g};{bg_b}m{' ' * panel_width}\033[0m")

    print("")  # Empty line between panels

    # Build rows for horizontal layout on light bg
    bg_r, bg_g, bg_b = bg_light_rgb

    # Top margin (increased) with title
    print(f"\033[48;2;{bg_r};{bg_g};{bg_b}m{' ' * panel_width}\033[0m")
    print(f"\033[48;2;{bg_r};{bg_g};{bg_b}m{' ' * panel_width}\033[0m")
    print(f"\033[48;2;{bg_r};{bg_g};{bg_b}m{' ' * panel_width}\033[0m")
    # Title on background with dark text
    title_text = f"On Light Background ({bg_light})"
    title_padding = (panel_width - len(title_text)) // 2
    print(f"\033[48;2;{bg_r};{bg_g};{bg_b}m\033[38;2;0;0;0m{' ' * title_padding}{title_text}{' ' * (panel_width - title_padding - len(title_text))}\033[0m")
    print(f"\033[48;2;{bg_r};{bg_g};{bg_b}m{' ' * panel_width}\033[0m")
    print(f"\033[48;2;{bg_r};{bg_g};{bg_b}m{' ' * panel_width}\033[0m")

    row1 = f"\033[48;2;{bg_r};{bg_g};{bg_b}m    "
    row2 = f"\033[48;2;{bg_r};{bg_g};{bg_b}m    "
    row3 = f"\033[48;2;{bg_r};{bg_g};{bg_b}m    "
    row4 = f"\033[48;2;{bg_r};{bg_g};{bg_b}m    "
    row5 = f"\033[48;2;{bg_r};{bg_g};{bg_b}m    "

    for i, color in enumerate(colors):
        try:
            r, g, b = hex_to_rgb(color)
            spacing = "   " if i < len(colors) - 1 else ""
            row1 += f"\033[48;2;{r};{g};{b}m        \033[0m\033[48;2;{bg_r};{bg_g};{bg_b}m{spacing}"
            row2 += f"\033[48;2;{r};{g};{b}m        \033[0m\033[48;2;{bg_r};{bg_g};{bg_b}m{spacing}"
            row3 += f"\033[48;2;{r};{g};{b}m        \033[0m\033[48;2;{bg_r};{bg_g};{bg_b}m{spacing}"
            row4 += f"\033[48;2;{r};{g};{b}m        \033[0m\033[48;2;{bg_r};{bg_g};{bg_b}m{spacing}"
            row5 += f"\033[48;2;{bg_r};{bg_g};{bg_b}m\033[38;2;0;0;0m {color:^7}\033[0m\033[48;2;{bg_r};{bg_g};{bg_b}m{spacing}"
        except:
            pass

    print(row1 + f"\033[48;2;{bg_r};{bg_g};{bg_b}m    \033[0m")
    print(row2 + f"\033[48;2;{bg_r};{bg_g};{bg_b}m    \033[0m")
    print(row3 + f"\033[48;2;{bg_r};{bg_g};{bg_b}m    \033[0m")
    print(row4 + f"\033[48;2;{bg_r};{bg_g};{bg_b}m    \033[0m")
    print(f"\033[48;2;{bg_r};{bg_g};{bg_b}m{' ' * panel_width}\033[0m")
    print(row5 + f"\033[48;2;{bg_r};{bg_g};{bg_b}m    \033[0m")

    # Bottom margin
    print(f"\033[48;2;{bg_r};{bg_g};{bg_b}m{' ' * panel_width}\033[0m")
    print(f"\033[48;2;{bg_r};{bg_g};{bg_b}m{' ' * panel_width}\033[0m\n")

def save_palette(filename, colors, bg_dark=None, bg_light=None):
    """Save colors to text file"""
    with open(filename, 'w') as f:
        if bg_dark:
            f.write(f"bg-dark: {bg_dark}\n")
        if bg_light:
            f.write(f"bg-light: {bg_light}\n")
        if bg_dark or bg_light:
            f.write("\n")
        f.write('\n'.join(colors))
    print(f"✓ Saved {len(colors)} colors to {filename}")

def load_palette(filename):
    """Load colors from text file"""
    colors = []
    bg_dark = None
    bg_light = None

    with open(filename, 'r') as f:
        for line in f:
            line = line.strip()
            if not line or line.startswith('#') and ':' not in line:
                # Regular color or empty line
                if line and not line.startswith('bg-'):
                    colors.append(line)
            elif line.startswith('bg-dark:'):
                bg_dark = line.split(':', 1)[1].strip()
            elif line.startswith('bg-light:'):
                bg_light = line.split(':', 1)[1].strip()
            elif not line.startswith('bg-'):
                # Regular color
                colors.append(line)

    return colors, bg_dark, bg_light

def show_web(colors, bg_light='#FFFFFF', bg_dark='#000000'):
    """Generate HTML and open in browser"""
    html = f"""<!DOCTYPE html>
<html>
<head>
    <title>Color Palette</title>
    <style>
        body {{
            font-family: monospace;
            padding: 20px;
            background: #2a2a2a;
            color: white;
        }}
        h1 {{
            margin-bottom: 30px;
        }}
        h2 {{
            margin-top: 0;
            margin-bottom: 30px;
            font-size: 16px;
            text-transform: uppercase;
            letter-spacing: 2px;
            text-align: left;
            padding: 20px 20px 20px 0;
        }}
        .section {{
            margin-bottom: 30px;
            padding: 40px;
            border-radius: 0;
        }}
        .dark-bg {{
            background: {bg_dark};
        }}
        .light-bg {{
            background: {bg_light};
        }}
        .dark-bg h2 {{
            color: white;
        }}
        .light-bg h2 {{
            color: black;
        }}
        .palette {{
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
            justify-content: center;
        }}
        .color {{
            text-align: center;
        }}
        .swatch {{
            width: 120px;
            height: 120px;
            border-radius: 0;
            box-shadow: none;
            margin-bottom: 10px;
        }}
        .hex {{
            font-size: 13px;
            font-weight: bold;
            padding: 5px;
            border-radius: 0;
            background: transparent;
        }}
        .dark-bg .hex {{
            color: white;
        }}
        .light-bg .hex {{
            color: black;
        }}
    </style>
</head>
<body>
    <h1>Color Palette</h1>

    <div class="section dark-bg">
        <h2>On Dark Background ({bg_dark})</h2>
        <div class="palette">
"""
    for color in colors:
        html += f"""            <div class="color">
                <div class="swatch" style="background: {color};"></div>
                <div class="hex">{color}</div>
            </div>
"""
    html += f"""        </div>
    </div>

    <div class="section light-bg">
        <h2>On Light Background ({bg_light})</h2>
        <div class="palette">
"""
    for color in colors:
        html += f"""            <div class="color">
                <div class="swatch" style="background: {color};"></div>
                <div class="hex">{color}</div>
            </div>
"""
    html += """        </div>
    </div>
</body>
</html>"""

    # Write to temp file and open
    with tempfile.NamedTemporaryFile(mode='w', suffix='.html', delete=False) as f:
        f.write(html)
        temp_path = f.name

    # Open in default browser
    import subprocess
    import platform

    try:
        # Try to use system default browser
        if platform.system() == 'Linux':
            subprocess.run(['xdg-open', temp_path], check=False)
        elif platform.system() == 'Darwin':  # macOS
            subprocess.run(['open', temp_path], check=False)
        elif platform.system() == 'Windows':
            subprocess.run(['start', temp_path], shell=True, check=False)
        else:
            webbrowser.open('file://' + temp_path)
    except:
        webbrowser.open('file://' + temp_path)

    print(f"✓ Opened in browser: {temp_path}")

def usage():
    """Print usage information"""
    print("""
Usage:
  palette save <file> <color1> <color2> ... [OPTIONS]    Save colors to file
  palette show <file> [OPTIONS]                          Show palette in terminal
  palette web <file> [OPTIONS]                           Show palette in browser
  palette add <file> <color1> <color2> ...               Add colors to existing file

Options:
  --bg-dark HEX    Background color for dark mode (default: #000000)
  --bg-light HEX   Background color for light mode (default: #FFFFFF)

File Format:
  Background colors are saved in the palette file and auto-loaded:

    bg-dark: #1a1a2e
    bg-light: #f5f5f5

    #6C5CE7
    #A29BFE
    #FF6B9D

Examples:
  # Save palette with backgrounds
  palette save sonoptic.txt "#6C5CE7" "#A29BFE" --bg-dark "#000" --bg-light "#fff"

  # Show palette (uses saved backgrounds)
  palette show sonoptic.txt

  # Override backgrounds temporarily
  palette show sonoptic.txt --bg-dark "#1a1a2e"

  # View in browser
  palette web sonoptic.txt

  # Add more colors (preserves backgrounds)
  palette add sonoptic.txt "#00B894"
""")

if __name__ == '__main__':
    if len(sys.argv) < 2:
        usage()
        sys.exit(1)

    command = sys.argv[1]

    # Handle help flags
    if command in ['-h', '--help', 'help']:
        usage()
        sys.exit(0)

    if command == 'save':
        if len(sys.argv) < 4:
            print("Error: Need filename and at least one color")
            usage()
            sys.exit(1)
        filename = sys.argv[2]

        # Parse colors and background options
        colors = []
        bg_dark = None
        bg_light = None
        args = sys.argv[3:]
        i = 0
        while i < len(args):
            if args[i] == '--bg-dark' and i + 1 < len(args):
                bg_dark = args[i + 1]
                i += 2
            elif args[i] == '--bg-light' and i + 1 < len(args):
                bg_light = args[i + 1]
                i += 2
            else:
                colors.append(args[i])
                i += 1

        save_palette(filename, colors, bg_dark=bg_dark, bg_light=bg_light)

        # Use saved backgrounds or defaults for display
        display_bg_dark = bg_dark if bg_dark else '#000000'
        display_bg_light = bg_light if bg_light else '#FFFFFF'
        show_terminal(colors, bg_light=display_bg_light, bg_dark=display_bg_dark)

    elif command == 'show':
        if len(sys.argv) < 3:
            print("Error: Need filename")
            usage()
            sys.exit(1)
        filename = sys.argv[2]
        colors, file_bg_dark, file_bg_light = load_palette(filename)

        # Parse optional background colors (command line overrides file)
        bg_dark = '#000000'
        bg_light = '#FFFFFF'
        args = sys.argv[3:]
        i = 0
        while i < len(args):
            if args[i] == '--bg-dark' and i + 1 < len(args):
                bg_dark = args[i + 1]
                i += 2
            elif args[i] == '--bg-light' and i + 1 < len(args):
                bg_light = args[i + 1]
                i += 2
            else:
                i += 1

        # Use file backgrounds if not overridden
        if file_bg_dark and bg_dark == '#000000':
            bg_dark = file_bg_dark
        if file_bg_light and bg_light == '#FFFFFF':
            bg_light = file_bg_light

        show_terminal(colors, bg_light=bg_light, bg_dark=bg_dark)

    elif command == 'web':
        if len(sys.argv) < 3:
            print("Error: Need filename")
            usage()
            sys.exit(1)
        filename = sys.argv[2]
        colors, file_bg_dark, file_bg_light = load_palette(filename)

        # Parse optional background colors (command line overrides file)
        bg_dark = '#000000'
        bg_light = '#FFFFFF'
        args = sys.argv[3:]
        i = 0
        while i < len(args):
            if args[i] == '--bg-dark' and i + 1 < len(args):
                bg_dark = args[i + 1]
                i += 2
            elif args[i] == '--bg-light' and i + 1 < len(args):
                bg_light = args[i + 1]
                i += 2
            else:
                i += 1

        # Use file backgrounds if not overridden
        if file_bg_dark and bg_dark == '#000000':
            bg_dark = file_bg_dark
        if file_bg_light and bg_light == '#FFFFFF':
            bg_light = file_bg_light

        show_web(colors, bg_light=bg_light, bg_dark=bg_dark)

    elif command == 'add':
        if len(sys.argv) < 4:
            print("Error: Need filename and at least one color")
            usage()
            sys.exit(1)
        filename = sys.argv[2]
        new_colors = sys.argv[3:]
        try:
            existing, bg_dark, bg_light = load_palette(filename)
        except FileNotFoundError:
            existing = []
            bg_dark = None
            bg_light = None
        all_colors = existing + new_colors
        save_palette(filename, all_colors, bg_dark=bg_dark, bg_light=bg_light)

        # Use saved backgrounds or defaults for display
        display_bg_dark = bg_dark if bg_dark else '#000000'
        display_bg_light = bg_light if bg_light else '#FFFFFF'
        show_terminal(all_colors, bg_light=display_bg_light, bg_dark=display_bg_dark)

    else:
        print(f"Unknown command: {command}")
        usage()
        sys.exit(1)
